#!input=油价地区

[Script]

cron "0 18 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/youjia2.js, tag=油价
cron "0 10 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/exchange.js, enable=true, tag=汇率
cron "0 11 * * 5,6,7" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/epic.js,  tag=EPIC
cron "0 10 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/iosapp.js, tag=ios限免
cron "0 10 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/iDaily.js,  tag=iDaily
