#!name=Plug in签到🌍
#!desc=每日签到
#!author=FIREHYYY
#!openUrl=
#!homepage=https://github.com/FIREHYYY/loon-script
#!icon=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/MM.png


[Script]
cron "30 7 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/bilibili.js, tag=B站每日等级任务
http-request ^https?:\/\/app\.bilibili\.com\/x\/resource\/domain\? script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/bilibili.js, tag=B站Cookie(APP)
http-request ^https?:\/\/m.bilibili.com/$ script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/bilibili.js, tag=B站Cookie(网页)
cron "30 7 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/aliyundrive.js, tag=阿里云盘
http-request ^https:\/\/auth\.aliyundrive\.com\/v2\/account\/token script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/aliyundrive.js, requires-body=true, timeout=10, enabled=true, tag=阿里云盘token
cron "30 7 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/smzdm.js,timeout=60,tag=什么值得买
http-request ^https?:\/\/user-api\.smzdm\.com\/checkin$ script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/smzdm.js,tag=什么值得买Cookie
cron "30 7 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/iqiyi.js,  tag=爱奇艺
http-request ^https:\/\/(m|api)\.bilibili\.com\/(x\/v\d\/history\/shadow|service-worker).* script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/bilibiliCoins.js, timeout=10, tag=bilibiliCoinsCookie
cron "25 15 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/bilibiliCoins.js,tag=bilibiliCoins
http-request ^https:\/\/yunbusiness\.ccb\.com\/clp_coupon\/txCtrl\?txcode=A3341A040 script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/jhsh.js,requires-body=1,tag=建行生活Cookie
cron "17 7 * * *" script-path=https://raw.githubusercontent.com/FIREHYYY/loon-script/main/jhsh.js,tag = 建行生活

[MITM]
hostname = user-api.smzdm.com,app.bilibili.com,m.bilibili.com,api.bilibili.com,auth.aliyundrive.com,yunbusiness.ccb.com


