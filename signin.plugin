# 微信自动阅读（羊毛）
http-response ^https?://mp\.weixin\.qq\.com/s\?.* script-path=https://github.com/ddgksf2013/Scripts/raw/master/wechat_auto_read.js, requires-body=true, timeout=10, tag=微信自动阅读（羊毛）


[MITM]
hostname = user-api.smzdm.com,app.moutai519.com.cn,app.bilibili.com,m.bilibili.com,api.bilibili.com,auth.alipan.com, auth.aliyundrive.com,yunbusiness.ccb.com,api.m.jd.com,app.moutai519.com.cn,rewards.bing.com,miniapp.yaduo.com,*.amap.com,webapi.qmai.cn,api.cloud.189.cn,www.52pojie.cn,*.hifini.com,cauth.pupuapi.com
